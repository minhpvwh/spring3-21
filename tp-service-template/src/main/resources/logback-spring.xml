<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Include platform logging defaults -->
    <include resource="tp-logback-defaults.xml"/>

    <!-- Local development: plain text -->
    <springProfile name="dev,local">
        <root level="INFO">
            <appender-ref ref="PLAIN_CONSOLE"/>
        </root>
    </springProfile>

    <!-- UAT and Production: structured JSON for ELK -->
    <springProfile name="uat,prod">
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
    </springProfile>

    <!-- Default (no profile): plain text -->
    <springProfile name="default">
        <root level="INFO">
            <appender-ref ref="PLAIN_CONSOLE"/>
        </root>
    </springProfile>
</configuration>
