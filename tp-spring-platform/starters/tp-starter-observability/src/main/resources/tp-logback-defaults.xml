<?xml version="1.0" encoding="UTF-8"?>
<included>
    <!-- Structured JSON logging for ELK -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>tracingId</includeMdcKeyName>
            <includeMdcKeyName>transactionId</includeMdcKeyName>
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>spanId</includeMdcKeyName>
            <fieldNames>
                <timestamp>@timestamp</timestamp>
                <version>[ignore]</version>
            </fieldNames>
            <customFields>{"service":"${spring.application.name:-unknown}"}</customFields>
        </encoder>
    </appender>

    <!-- Plain text for local development -->
    <appender name="PLAIN_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{tracingId:-}] [%X{transactionId:-}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
</included>
